# Database configuration (PostgreSQL - used for historical data analysis)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homeassistant
DB_USER=ml_agent
DB_PASSWORD=your_postgres_password_here

# Home Assistant configuration
HA_HOST=http://192.168.0.1:8123
HA_TOKEN=your_home_assistant_token_here

# Electricity pricing and tariffs
ELECTRICITY_TAX_EUR_PER_KWH=0.025
GRID_TRANSFER_EUR_PER_KWH=0.03
IMPORT_FIXED_ADDERS_EUR_PER_KWH=0.01
IMPORT_VAT_MULTIPLIER=1.24
EXPORT_DEDUCTION_EUR_PER_KWH=0.02

# Battery optimization settings
BATTERY_CHARGE_PERCENTILE=25
BATTERY_DISCHARGE_PERCENTILE=60
BATTERY_MIN_SOC_PCT=10.0
BATTERY_MAX_SOC_PCT=90.0
BATTERY_RESERVE_SOC_PCT=10.0
BATTERY_CAPACITY_KWH=50.0
BATTERY_MAX_CHARGE_KW=10.0
BATTERY_MAX_DISCHARGE_KW=10.0
BATTERY_CHARGE_EFFICIENCY=0.95
BATTERY_DISCHARGE_EFFICIENCY=0.95
BATTERY_ALLOW_EXPORT=true
BATTERY_INITIAL_SOC_PCT=50

# Self-reliance penalty: discourages grid charging when solar surplus is expected.
# Set to 0.0 to disable (pure cost optimization). Typical value: 0.02-0.05
BATTERY_SELF_RELIANCE_PENALTY_EUR_PER_KWH=0.0

# GSHP (Ground Source Heat Pump) settings
GSHP_INITIAL_TEMP=50.0
GSHP_MIN_TEMP=42.0
GSHP_MAX_TEMP=55.0
GSHP_IS_RUNNING=false
GSHP_ELECTRIC_POWER_KW=4.0
GSHP_COP=3.5
GSHP_HEAT_LOSS_K=0.1
GSHP_BASELINE_DEMAND_KW=1.0
GSHP_POWER_MIN_KW=3.4
GSHP_POWER_MAX_KW=4.2
GSHP_STRATEGIC_STOP_DIFF_EUR=0.05

# EV charging settings
EV_TARGET_SOC_PCT=80.0
EV_CAPACITY_KWH=60.0
EV_CHARGE_POWER_KW=3.5
EV_CHARGE_HOURS=4.0

# Planning configuration
PLAN_INTERVAL_MINUTES=15
