# Database configuration (PostgreSQL - used for historical data analysis)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homeassistant
DB_USER=ml_agent
DB_PASSWORD=your_postgres_password_here

# Home Assistant configuration
HA_HOST=http://192.168.0.1:8123
HA_TOKEN=your_home_assistant_token_here

# Electricity pricing and tariffs
# All values are in EUR per kWh unless noted otherwise.
# These are applied by build_tariff_prices() in optimize_plan.py.
ELECTRICITY_TAX_EUR_PER_KWH=0.025          # Tax added to imported electricity (skipped if prices are already inclusive)
GRID_TRANSFER_EUR_PER_KWH=0.03             # Grid transfer fee added to imported electricity (skipped if prices are already inclusive)
IMPORT_FIXED_ADDERS_EUR_PER_KWH=0.01       # Fixed adders always added to the import price before VAT
IMPORT_VAT_MULTIPLIER=1.24                 # VAT multiplier applied to the total import price (e.g. 1.24 for 24 % VAT)
EXPORT_DEDUCTION_EUR_PER_KWH=0.02          # Deduction subtracted from the spot price when calculating export revenue (clamped at 0)

# Battery optimization settings
# If BATTERY_CAPACITY_KWH is 0, the optimizer returns a no-op (idle) battery plan.
BATTERY_CHARGE_PERCENTILE=25               # Import-price percentile below which grid charging is considered cheap. Default in code is 30.
BATTERY_DISCHARGE_PERCENTILE=60            # Import-price percentile above which discharging to load is triggered. Default in code is 70.
BATTERY_MIN_SOC_PCT=10.0                   # Minimum allowed State of Charge (%) during normal operation. Hard floor used by the optimizer.
BATTERY_MAX_SOC_PCT=90.0                   # Maximum allowed State of Charge (%) during normal operation.
BATTERY_RESERVE_SOC_PCT=10.0               # Emergency reserve SOC (%). Defaults to BATTERY_MIN_SOC_PCT in code if omitted. The actual floor is max(MIN, RESERVE).
BATTERY_CAPACITY_KWH=50.0                  # Total usable battery capacity in kWh. Set to 0 to disable battery simulation.
BATTERY_MAX_CHARGE_KW=10.0                 # Maximum charge power in kW (inverter / BMS limit).
BATTERY_MAX_DISCHARGE_KW=10.0              # Maximum discharge power in kW (inverter / BMS limit).
BATTERY_CHARGE_EFFICIENCY=0.95             # Charge conversion efficiency (0.0-1.0). Clamped to [0.01, 1.0] in code.
BATTERY_DISCHARGE_EFFICIENCY=0.95          # Discharge conversion efficiency (0.0-1.0). Clamped to [0.01, 1.0] in code.
BATTERY_ALLOW_EXPORT=true                  # When false, discharge is restricted to self-consumption (discharge_to_export is blocked).
BATTERY_INITIAL_SOC_PCT=50                 # Fallback starting SOC (%) when sensor.be_soc is unavailable in Home Assistant.

# Self-reliance penalty: added to the effective import price when solar surplus is expected later.
# This discourages grid charging in favour of waiting for free solar. Set to 0.0 for pure cost optimization.
# Typical values: 0.02-0.05 EUR/kWh.
BATTERY_SELF_RELIANCE_PENALTY_EUR_PER_KWH=0.0

# GSHP (Ground Source Heat Pump) settings
# At runtime GSHP_INITIAL_TEMP and GSHP_IS_RUNNING are overwritten by HA sensors
# (sensor.mlp_varaajan_lampotila and sensor.mlp_teho respectively) when available.
GSHP_INITIAL_TEMP=50.0                     # Starting accumulator / buffer temperature (°C). Fallback when HA sensor is unavailable.
GSHP_MIN_TEMP=42.0                         # Hard minimum accumulator temperature (°C). Heat pump MUST start if temp drops to or below this.
GSHP_MAX_TEMP=55.0                         # Hard maximum accumulator temperature (°C). Heat pump MUST stop if temp reaches this.
GSHP_IS_RUNNING=false                      # Initial on/off state. Fallback when HA power sensor is unavailable.
GSHP_ELECTRIC_POWER_KW=4.0                 # Fallback nominal power. Only used when GSHP_POWER_MIN_KW and GSHP_POWER_MAX_KW are BOTH absent; in that case min and max are set to this value.
GSHP_COP=3.5                               # Coefficient of Performance (thermal output / electrical input).
GSHP_HEAT_LOSS_K=0.1                       # House heat-loss coefficient used in demand calculation: max(0, (20.0 - outside_temp) * heat_loss_k). Default in code is 0.135.
GSHP_BASELINE_DEMAND_KW=1.0                # Baseline thermal demand (kW) for DHW, circulation and standby. Added to the weather-driven heat loss.
GSHP_POWER_MIN_KW=3.4                      # Minimum electrical power the compressor can modulate down to (at min_temp). Forms a linear ramp with MAX.
GSHP_POWER_MAX_KW=4.2                      # Maximum electrical power the compressor can draw (at max_temp). Forms a linear ramp with MIN.
GSHP_STRATEGIC_STOP_DIFF_EUR=0.05          # Spot-price difference threshold (EUR/kWh). If current effective price >= (cheapest price in lookahead window + this value), the heat pump stops strategically.

# EV charging settings
# The optimizer prefers to use the real-time EV SoC from sensor.xpz_491_battery_level.
# These values are used as fallbacks / targets when that sensor is unavailable or already at target.
EV_TARGET_SOC_PCT=80.0                     # Desired final State of Charge after charging (%).
EV_CAPACITY_KWH=60.0                       # EV battery capacity (kWh).
EV_CHARGE_POWER_KW=3.5                     # Charger power level (kW).
EV_CHARGE_HOURS=4.0                        # Fallback continuous charging duration (hours) used only when the current EV SoC is unknown.

# Planning configuration
PLAN_INTERVAL_MINUTES=15                   # Time granularity of the optimization horizon in minutes. Affects battery, GSHP and EV slot calculations.
